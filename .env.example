# Frontend public data base URL.
# The frontend appends paths such as:
# - gold/filosofi/metadata.json
# - gold/filosofi/indicator_availability.json
# - gold/filosofi/commune_all_years.parquet
#
# If your public R2 URL includes a path prefix, include it here.
# Trailing slashes are handled by the frontend code.
VITE_DATA_ASSET_BASE_URL=https://example.r2.dev/<public-prefix>

# Never expose R2 credentials in a VITE_ variable.
# R2 access keys are reserved for Python scripts and GitHub Actions workflows.
